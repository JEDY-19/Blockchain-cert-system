# SECURITY: Copy this file to .env — never commit .env (keep .env in .gitignore).
# Never share your PRIVATE_KEY or any real private keys. Anyone with PRIVATE_KEY controls the deployer wallet.
# SEPOLIA_RPC_URL often contains API secrets; treat it as confidential.

# Copy to .env and fill in for Hardhat deploy + optional overrides
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=0xYourSepoliaDeployerPrivateKey

# After deploy — also update MySQL settings.contract_address or rely on this for PHP getenv:
CONTRACT_ADDRESS=

# Credentialed CORS for admin/student APIs (comma-separated origins: scheme://host[:port] only, no path)
# Required in production (APP_ENV=production). Example: CORS_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.edu

# Public site URL (used in QR codes / verify links). Use HTTPS in production to reduce MITM risk on verification links.
APP_PUBLIC_URL=https://localhost/Blockchain-cert-system
